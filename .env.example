# ==============================================================================
# SENTINEL Enterprise ASPM Platform Environment Variables Blueprint
# Copy this file to '.env' and modify the values for your target setup.
# ==============================================================================

# --- DATABASE SETTINGS ---
# Connection details for core PostgreSQL relational database
POSTGRES_DB=sentinel_db
POSTGRES_USER=sentinel_user
POSTGRES_PASSWORD=sentinel_password
DATABASE_URL=postgresql://sentinel_user:sentinel_password@localhost:5432/sentinel_db

# --- MESSAGE BROKER ---
# Connection URL to Redis broker for Celery and WebSocket channels
REDIS_URL=redis://localhost:6379/0

# --- GRAPH TOPOLOGY DATABASE ---
# Neo4j connection details to visual attack path analysis
NEO4J_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- LLM AI ADAPTER SETTINGS ---
# Unified Provider: 'ollama', 'openai', or 'anthropic'
AI_PROVIDER=ollama
# Authentication API key (Leave blank for local Ollama)
AI_API_KEY=
# Target LLM model: e.g. 'llama3', 'gpt-4o', or 'claude-3-opus'
AI_MODEL=llama3
# Custom model endpoint URL (Optional)
AI_BASE_URL=http://localhost:11434/api/generate

# --- SECURITY SETTINGS ---
# Base64-encoded 32-byte Fernet key for encrypting sensitive data
SENTINEL_ENCRYPTION_KEY=

# --- DEV SERVER OPTIONS ---
# Host bind options for backend API
HOST=0.0.0.0
PORT=8000
DEBUG=false
